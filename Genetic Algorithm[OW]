orch.distributions import Categorical, Beta\nfrom tqdm import tqdm\n\ndevice = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\nprint(\"Device:\", device)\n\nenv = make(\"orbit_wars\", debug=False)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-23T05:16:00.921442Z","iopub.execute_input":"2026-04-23T05:16:00.921877Z","iopub.status.idle":"2026-04-23T05:16:00.982276Z","shell.execute_reply.started":"2026-04-23T05:16:00.921820Z","shell.execute_reply":"2026-04-23T05:16:00.981611Z"}},"outputs":[{"name":"stdout","text":"Device: cuda\n","output_type":"stream"}],"execution_count":15},{"cell_type":"code","source":"class Config:\n    # Indices\n    ID, OWNER, X, Y, RADIUS, SHIPS, PROD = 0, 1, 2, 3, 4, 5, 6\n\n    # Sun\n    SUN_X, SUN_Y, SUN_R = 50, 50, 10\n\n    # Planets\n    max_planets = 44\n\n    # Network\n    input_size = 1024\n    hidden_size = 128\n    out = 64\n\nCFG = Config()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-23T05:16:00.983960Z","iopub.execute_input":"2026-04-23T05:16:00.984435Z","iopub.status.idle":"2026-04-23T05:16:00.988970Z","shell.execute_reply.started":"2026-04-23T05:16:00.984406Z","shell.execute_reply":"2026-04-23T05:16:00.988329Z"}},"outputs":[],"execution_count":16},{"cell_type":"code","source":"def gen_features(obs, size=1024):\n    player = obs.get(\"player\", 0)\n    planets = [Planet(*p) for p in obs.get(\"planets\", [])]\n    fleets = [Fleet(*f) for f in obs.get(\"fleets\", [])]\n    angular_velocity = obs.get(\"angular_velocity\", 0.0)\n\n    features = [angular_velocity]\n\n    uncolonized_planets = [p for p in planets if p.owner != player]\n\n    for p in planets:\n        closest_distance = min(\n            math.hypot(p.x - target_planet.x, p.y - target_planet.y)\n            for target_planet in uncolonized_planets\n        ) if uncolonized_planets else 0.0\n\n        orbital_radius = math.hypot(p.x - CFG.SUN_X, p.y - CFG.SUN_Y)\n\n        features.extend([\n            float(p.owner == player),\n            p.x,\n            p.y,\n            p.ships,\n            p.production,\n            orbital_radius,\n            float(orbital_radius + p.radius < 50),\n            closest_distance,\n        ]) # até 400 features\n\n    for f in fleets:\n        features.extend([\n            float(f.owner ==  player),\n            f.x,\n            f.y,\n            f.ships,\n            f.from_planet_id,\n            math.cos(f.angle),\n            math.sin(f.angle),\n        ])\n\n    x = np.zeros(CFG.input_size, dtype=np.float32)\n    l = min(len(features), CFG.input_size)\n    x[:l] = features[:l]\n\n    norm = np.linalg.norm(x) \n    return x / (norm + 1e-8)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-23T05:16:00.990356Z","iopub.execute_input":"2026-04-23T05:16:00.990770Z","iopub.status.idle":"2026-04-23T05:16:01.001886Z","shell.execute_reply.started":"2026-04-23T05:16:00.990739Z","shell.execute_reply":"2026-04-23T05:16:01.000839Z"}},"outputs":[],"execution_count":17},{"cell_type":"code","source":"def fleet_speed(n):\n    if n <= 1:\n        return 1.0\n    return 1.0 + (6.0 - 1.0) * (math.log(max(n, 2)) / math.log(1000)) ** 1.5\n\ndef future_pos(planet, t, w):\n    px, py, r = planet.x, planet.y, planet.radius\n    dist = math.hypot(px - CFG.SUN_X, py - CFG.SUN_Y)\n    if dist + r >= 50 or w == 0:\n        return px, py\n    angle = math.atan2(py - CFG.SUN_Y, px - CFG.SUN_X)\n    na = angle + w * t\n    return CFG.SUN_X + dist * math.cos(na), CFG.SUN_Y + dist * math.sin(na)\n\ndef intercept(src, tgt, n_ships, w, iters=4):\n    spd = fleet_speed(n_ships)\n    dist = math.hypot(tgt.x - src.x, tgt.y - src.y)\n    t = dist / spd\n    for _ in range(iters):\n        fx, fy = future_pos(tgt, t, w)\n        t = math.hypot(fx - src.x, fy - src.y) / spd\n    fx, fy = future_pos(tgt, t, w)\n    return math.atan2(fy - src.y, fx - src.x), t, fx, fy","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-23T05:16:01.003042Z","iopub.execute_input":"2026-04-23T05:16:01.003382Z","iopub.status.idle":"2026-04-23T05:16:01.017794Z","shell.execute_reply.started":"2026-04-23T05:16:01.003325Z","shell.execute_reply":"2026-04-23T05:16:01.016784Z"}},"outputs":[],"execution_count":18},{"cell_type":"code","source":"class Agent(nn.Module):\n    def __init__(self, \n                 input_size=CFG.input_size, \n                 hidden_size=CFG.hidden_size, \n                 out=CFG.out,\n                 n_planets=CFG.max_planets):\n        \n        super().__init__()\n\n        self.action_count = 0\n        self.planets_owned_history = []\n        \n        self.net = nn.Sequential(\n            nn.Linear(input_size, hidden_size),\n            nn.ReLU(),\n            nn.Linear(hidden_size, out),\n            nn.ReLU(),\n        )\n\n        self.source = nn.Linear(out, n_planets)\n        self.destiny = nn.Linear(out, n_planets)\n        self.alpha = nn.Linear(out, 1)\n        self.beta  = nn.Linear(out, 1)\n        self.actions = nn.Linear(out, 1)\n\n    def forward(self, x):\n        h = self.net(x)\n\n        # From to\n        source = self.source(h)\n        destiny = self.destiny(h)\n\n        # Ships\n        alpha = F.softplus(self.alpha(h)) + 1e-5\n        beta = F.softplus(self.beta(h))  + 1e-5\n\n        # Actions\n        n_actions = F.softplus(\n            self.actions(h)\n        ).round().int()\n        \n        return source, destiny, alpha, beta, n_actions\n\n    def act(self, obs):\n        player = obs.get(\"player\", 0)\n        planets = [Planet(*p) for p in obs.get(\"planets\", [])]\n        angular_v = obs.get(\"angular_velocity\", 0)\n        \n        owned   = [p.id for p in planets if p.owner == player]\n        self.planets_owned_history.append(len(owned))\n        \n        if not owned:\n            return []\n\n        features = gen_features(obs)\n        x = torch.FloatTensor(features).unsqueeze(0).to(device)\n\n        source, destiny, alpha, beta, number_of_actions = self.forward(x)\n\n        number_of_actions = number_of_actions.clamp(0, len(owned))\n\n        available = owned.copy()\n        actions = []\n        \n        mask = torch.full(\n            (CFG.max_planets,),\n            float('-inf'), \n            device=device\n        )\n        \n        for i in range(number_of_actions):\n            if not available:\n                break\n        \n            source_mask = mask.clone()\n            source_mask[available] = 0.0\n            source_idx = Categorical(logits=source.squeeze(0) + source_mask).sample().item()\n        \n            destiny_mask = mask.clone()\n            destiny_mask[[p.id for p in planets]] = 0.0\n            destiny_mask[source_idx] = float('-inf')\n            destiny_idx = Categorical(logits=destiny.squeeze(0) + destiny_mask).sample().item()\n        \n            frac = Beta(alpha, beta).sample().item()\n            ships = max(1, int(frac * planets[source_idx].ships))\n\n            angle, _, _, _ = intercept(planets[source_idx], planets[destiny_idx], ships, angular_v)\n\n            available.remove(source_idx)\n            actions.append([source_idx, angle, ships])\n\n        self.action_count += len(actions)\n        \n        return actions\n\n    def reset_stats(self):\n        self.action_count = 0\n        self.planets_owned_history = []\n    \n    def save(self, path):\n        torch.save(self.state_dict(), path)\n\n    def load(self, path):\n        self.load_state_dict(torch.load(path, map_location=device))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-23T05:16:01.018950Z","iopub.execute_input":"2026-04-23T05:16:01.019303Z","iopub.status.idle":"2026-04-23T05:16:01.036106Z","shell.execute_reply.started":"2026-04-23T05:16:01.019244Z","shell.execute_reply":"2026-04-23T05:16:01.035173Z"}},"outputs":[],"execution_count":19},{"cell_type":"code","source":"def get_params(agent):\n    return torch.cat([p.data.flatten() for p in agent.parameters()])\n\ndef set_params(agent, params):\n    idx = 0\n    for p in agent.parameters():\n        n = p.numel()\n        p.data.copy_(params[idx:idx+n].reshape(p.shape))\n        idx += n\n\ndef crossover(father, mother):\n    genes_father, genes_mother = get_params(father), get_params(mother)\n    mask = torch.rand_like(genes_father) > 0.5\n    child = Agent().to(device)\n    set_params(child, torch.where(mask, genes_father, genes_mother))\n    return child\n\ndef mutate(agent, std=0.02):\n    params = get_params(agent)\n    params += torch.randn_like(params) * std\n    set_params(agent, params)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-23T05:16:01.037062Z","iopub.execute_input":"2026-04-23T05:16:01.037497Z","iopub.status.idle":"2026-04-23T05:16:01.050686Z","shell.execute_reply.started":"2026-04-23T05:16:01.037452Z","shell.execute_reply":"2026-04-23T05:16:01.049802Z"}},"outputs":[],"execution_count":20},{"cell_type":"code","source":"def compute_fitness(state, idx, agent):\n    reward  = state[idx].reward or 0\n    obs     = state[idx].observation\n    step    = state[0].observation.step\n    player  = obs.player\n    planets = [Planet(*p) for p in obs.planets]\n    owned   = [p for p in planets if p.owner == player]\n\n    domination  = len(owned) / len(planets)\n    speed       = (500 - step) / 500 if reward > 0 else 0\n    \n    action_bonus    = agent.action_count / max(step, 1)\n    conquest_bonus = max(agent.planets_owned_history, default=0) / len(planets)\n    hoarding_penalty = sum(p.ships for p in owned) / max(sum(p.ships for p in planets), 1)\n\n    return (\n        reward       * 1000\n        + domination * 500\n        + speed * 300\n        + action_bonus  * 200\n        + conquest_bonus  * 200\n        - hoarding_penalty * 200\n    )\n\ndef tournament(population, fitnesses, k=3):\n    contestants = random.sample(list(zip(fitnesses, population)), k)\n    return max(contestants, key=lambda x: x[0])[1]","metadata":{"trus